# Copy this file to backend/.env and fill in your values

# SQLite (default) — change to postgresql+psycopg2://user:pass@host/db for PostgreSQL
DATABASE_URL=sqlite:///./marketpy.db

# Generate a strong random secret key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-secret-key

# JWT algorithm
ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
